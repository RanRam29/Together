{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/cards/**",
              "components/feedback/**",
              "components/forms/**",
              "components/layout/**",
              "components/selection/**",
              "ui_kits/parent-app/**",
              "ui_kits/professional-app/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Rubik))/i]",
        "message": "Font not provided by the design system. Available: Rubik."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|tone|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: children, tone."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:purple|slate|teal|amber|coral|neutral)$/]",
        "message": "<Badge> tone must be one of 'purple' | 'slate' | 'teal' | 'amber' | 'coral' | 'neutral'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Banner'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|eyebrow|title|actionLabel|onAction|message|key|ref|className|style|children)$/]",
        "message": "<Banner> doesn't accept that prop. Declared props: variant, eyebrow, title, actionLabel, onAction, message."
      },
      {
        "selector": "JSXOpeningElement[name.name='Banner'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:active|offline)$/]",
        "message": "<Banner> variant must be one of 'active' | 'offline'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|tone|fullWidth|disabled|loading|onClick|type|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, tone, fullWidth, disabled, loading, onClick, type."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:solid|outline)$/]",
        "message": "<Button> variant must be one of 'solid' | 'outline'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:purple|teal|coral)$/]",
        "message": "<Button> tone must be one of 'purple' | 'teal' | 'coral'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:button|submit)$/]",
        "message": "<Button> type must be one of 'button' | 'submit'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|padding|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: children, padding."
      },
      {
        "selector": "JSXOpeningElement[name.name='ChildSelectorChild'] > JSXAttribute > JSXIdentifier[name!=/^(?:id|name|key|ref|className|style|children)$/]",
        "message": "<ChildSelectorChild> doesn't accept that prop. Declared props: id, name."
      },
      {
        "selector": "JSXOpeningElement[name.name='ChipOption'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|key|ref|className|style|children)$/]",
        "message": "<ChipOption> doesn't accept that prop. Declared props: value, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='LetterCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:professionalName|photoUrl|childName|letter|onApprove|onDismiss|key|ref|className|style|children)$/]",
        "message": "<LetterCard> doesn't accept that prop. Declared props: professionalName, photoUrl, childName, letter, onApprove, onDismiss."
      },
      {
        "selector": "JSXOpeningElement[name.name='MatchCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|photoUrl|bio|matchReason|score|distanceLabel|ratingAvg|onClick|key|ref|className|style|children)$/]",
        "message": "<MatchCard> doesn't accept that prop. Declared props: name, photoUrl, bio, matchReason, score, distanceLabel, ratingAvg, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='MetricCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|highlight|onClick|key|ref|className|style|children)$/]",
        "message": "<MetricCard> doesn't accept that prop. Declared props: label, value, highlight, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='MetricCard'] > JSXAttribute[name.name='highlight'] > Literal[value!=/^(?:default|warning|success)$/]",
        "message": "<MetricCard> highlight must be one of 'default' | 'warning' | 'success'."
      },
      {
        "selector": "JSXOpeningElement[name.name='MultiChipOption'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|key|ref|className|style|children)$/]",
        "message": "<MultiChipOption> doesn't accept that prop. Declared props: value, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='OtpInput'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|onChange|length|key|ref|className|style|children)$/]",
        "message": "<OtpInput> doesn't accept that prop. Declared props: value, onChange, length."
      },
      {
        "selector": "JSXOpeningElement[name.name='PlaceholderCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:text|key|ref|className|style|children)$/]",
        "message": "<PlaceholderCard> doesn't accept that prop. Declared props: text."
      },
      {
        "selector": "JSXOpeningElement[name.name='RequestCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:childName|photoUrl|tags|statusLabel|statusTone|message|canRespond|onAccept|onReject|onViewProfile|key|ref|className|style|children)$/]",
        "message": "<RequestCard> doesn't accept that prop. Declared props: childName, photoUrl, tags, statusLabel, statusTone, message, canRespond, onAccept, onReject, onViewProfile."
      },
      {
        "selector": "JSXOpeningElement[name.name='RequestCard'] > JSXAttribute[name.name='statusTone'] > Literal[value!=/^(?:pending|interested|rejected)$/]",
        "message": "<RequestCard> statusTone must be one of 'pending' | 'interested' | 'rejected'."
      },
      {
        "selector": "JSXOpeningElement[name.name='RoleCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|description|selected|onClick|key|ref|className|style|children)$/]",
        "message": "<RoleCard> doesn't accept that prop. Declared props: title, description, selected, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='ScreenHeader'] > JSXAttribute > JSXIdentifier[name!=/^(?:eyebrow|title|subtitle|showBack|onBack|headerRight|key|ref|className|style|children)$/]",
        "message": "<ScreenHeader> doesn't accept that prop. Declared props: eyebrow, title, subtitle, showBack, onBack, headerRight."
      },
      {
        "selector": "JSXOpeningElement[name.name='StarRating'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|onChange|readOnly|max|key|ref|className|style|children)$/]",
        "message": "<StarRating> doesn't accept that prop. Declared props: label, value, onChange, readOnly, max."
      },
      {
        "selector": "JSXOpeningElement[name.name='SwitchToggle'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|description|value|onChange|disabled|key|ref|className|style|children)$/]",
        "message": "<SwitchToggle> doesn't accept that prop. Declared props: label, description, value, onChange, disabled."
      },
      {
        "selector": "JSXOpeningElement[name.name='TextField'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|placeholder|value|onChange|error|type|showPasswordToggle|key|ref|className|style|children)$/]",
        "message": "<TextField> doesn't accept that prop. Declared props: label, placeholder, value, onChange, error, type, showPasswordToggle."
      },
      {
        "selector": "JSXOpeningElement[name.name='TextField'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:text|password|tel|email)$/]",
        "message": "<TextField> type must be one of 'text' | 'password' | 'tel' | 'email'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
